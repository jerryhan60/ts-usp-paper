% forloop.sty - simple for-loop macro
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{forloop}[2006/09/18 v3.0 For-Loop Macro]
\RequirePackage{ifthen}
% Fix: the shipped forloop.sty had #4 and #5 swapped in the macro body,
% breaking the canonical [step]{counter}{init}{condition}{body} calling
% convention used by icml2026.sty (e.g. in \printAffiliationsAndNotice).
\newcommand{\forloop}[5][1]{%
  \setcounter{#2}{#3}%
  \ifthenelse{#4}{#5\addtocounter{#2}{#1}%
    \forloop[#1]{#2}{\value{#2}}{#4}{#5}}{}%
}
