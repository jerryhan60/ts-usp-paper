% neurips_2026.sty - Minimal NeurIPS 2026 style approximation
% Based on the standard NeurIPS formatting requirements.
% For final submission, download the official style file from neurips.cc.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/01 NeurIPS 2026 Style (approximation)]

\newif\if@neuripsfinal\@neuripsfinalfalse
\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripsfinalfalse}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax

% Page geometry: 5.5in x 9in text area
\RequirePackage[letterpaper,
  textwidth=5.5in,
  textheight=9in,
  marginparwidth=0.7in,
  top=1in,
  left=1.5in]{geometry}

% Fonts
\RequirePackage{times}
\RequirePackage{latexsym}

% natbib for citations
\RequirePackage[numbers,sort&compress]{natbib}

% Title formatting
\def\@maketitle{%
  \newpage
  \null
  \vskip 0.1in
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 0.15in
    \if@neuripsfinal
      {\normalsize
       \begin{tabular}[t]{c}%
         \@author
       \end{tabular}\par}%
    \else
      {\normalsize Anonymous Author(s)\par}%
    \fi
    \vskip 0.1in
  \end{center}%
  \par
  \vskip 0.1in
}

% Abstract formatting
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}\small
}{%
  \end{quote}%
}

% Section formatting
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-2.5ex \@plus -1ex \@minus -.2ex}%
  {1.0ex \@plus .2ex}%
  {\normalfont\large\bfseries}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-2.0ex \@plus -1ex \@minus -.2ex}%
  {0.5ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries}}

% Line spacing
\linespread{1.0}

% Running header
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhead{}
\fancyfoot{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

\if@neuripsfinal\else
  \fancyhead[C]{\small Submitted to NeurIPS 2026}
\fi

\endinput
